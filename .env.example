APP_NAME=Enterprise Headless CMS API
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
DATABASE_URL=postgresql+psycopg://cms:cms@postgres:5432/cms
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1,testserver,api
UPLOAD_DIR=./uploads
PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:8000/media
DEFAULT_LOCALE=en-US
DEFAULT_TIMEZONE=UTC
MAX_UPLOAD_BYTES=26214400
WEBHOOK_TIMEOUT_SECONDS=10
